# Mr.Holmes — Environment Variables Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
#
# Usage: python-dotenv loads these automatically at startup via Core/config/settings.py

# =============================================
# SMTP / Email Settings
# =============================================
MH_SMTP_STATUS=Disabled
MH_SMTP_EMAIL=
MH_SMTP_PASSWORD=
MH_SMTP_DESTINATION=
MH_SMTP_SERVER=smtp.gmail.com
MH_SMTP_PORT=587

# =============================================
# API Keys
# =============================================
# WHOIS / IP lookup API key (optional)
MH_API_KEY=

# Future integrations (uncomment when needed):
# MH_SHODAN_API_KEY=
# MH_HIBP_API_KEY=

# =============================================
# CLI Access Control
# =============================================
# Password to access Mr.Holmes CLI (leave blank to disable)
MH_CLI_PASSWORD=Holmes
