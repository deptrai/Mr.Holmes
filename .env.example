# Mr.Holmes — Environment Variables Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
#
# Usage: python-dotenv loads these automatically at startup via Core/config/settings.py

# =============================================
# SMTP / Email Settings
# =============================================
MH_SMTP_STATUS=Disabled
MH_SMTP_EMAIL=
MH_SMTP_PASSWORD=
MH_SMTP_DESTINATION=
MH_SMTP_SERVER=smtp.gmail.com
MH_SMTP_PORT=587

# =============================================
# API Keys — Epic 7 Plugin System
# =============================================
# WHOIS / IP lookup API key (optional)
MH_API_KEY=

# Shodan — port/scan/vulnerability lookup (https://shodan.io)
MH_SHODAN_API_KEY=

# HaveIBeenPwned — breach checker (https://haveibeenpwned.com/API/Key)
MH_HAVEIBEENPWNED_API_KEY=

# LeakLookup — breach data lookup (https://leaklookup.com)
MH_LEAKLOOKUP_API_KEY=

# Numverify — phone number validation (https://numverify.com)
MH_NUMVERIFY_API_KEY=

# GitHub — optional token for higher rate limits (https://github.com/settings/tokens)
MH_GITHUB_TOKEN=

# =============================================
# Epic 8/9 — Autonomous Profiler Settings
# =============================================
# SearxNG instance URL for OSINT search (leave blank to use DDG fallback)
MH_SEARXNG_URL=

# LLM Synthesizer — OpenAI-compatible API for report generation
MH_LLM_BASE_URL=
MH_LLM_API_KEY=
MH_LLM_MODEL=

# LLM fallback endpoint (used when primary fails)
MH_LLM_FALLBACK_BASE_URL=
MH_LLM_FALLBACK_API_KEY=
MH_LLM_FALLBACK_MODEL=

# =============================================
# Performance / Concurrency
# =============================================
# Max concurrent HTTP requests during OSINT scans (default: 5)
MR_HOLMES_CONCURRENCY=5

# Plugin cache TTL in seconds (default: 3600 = 1 hour)
MH_CACHE_TTL=3600

# Plugin cache max entries (default: 500)
MH_CACHE_MAX_ENTRIES=500

# =============================================
# CLI Access Control
# =============================================
# Password to access Mr.Holmes CLI (leave blank to disable)
MH_CLI_PASSWORD=Holmes
